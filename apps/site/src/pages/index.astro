---
import PageLayout from '@theme/PageLayout.astro'
import { getCollection, getEntry, render } from 'astro:content'
import { loadThemeOptions } from '../lib/site-config'
import { loadSiteSettings } from '../lib/site-settings'
import { feedLocales } from '../lib/feed'
import { pageSeo } from '../lib/seo'
import { parsePageSeoOverride } from '@setu/core'
import { resolveMediaBase } from '@setu/image-astro'

const themeOptions = loadThemeOptions()
const siteSettings = loadSiteSettings()
const mediaBase = resolveMediaBase(import.meta.env.PUBLIC_SETU_MEDIA, import.meta.env.DEV)
const homepageId = siteSettings.reading.homepage
// #165: a draft (`published: false`) homepage renders as if unset — fall through to the
// default home entry, or the empty shell. A draft must never render publicly, even here.
const ifPublished = (e: Awaited<ReturnType<typeof getEntry>>) =>
  e && (e.data as { published?: unknown }).published !== false ? e : undefined
const entry =
  ifPublished(await getEntry('entries', homepageId)) ??
  ifPublished(await getEntry('entries', 'page/en/home'))
const title = entry ? ((entry.data as { title?: string }).title ?? 'Home') : 'Home'
const rendered = entry ? await render(entry) : null
const Content = rendered?.Content
const localesForFeed = feedLocales(
  (await getCollection('entries')).map((e) => ({ id: e.id, data: e.data as Record<string, unknown> })),
)
// Homepage: <title> is the bare site name (empty page title) — the standard root-page convention —
// unless the homepage document sets a per-page `seo:` override.
const ov = entry ? parsePageSeoOverride(entry.data) : {}
const seo = pageSeo(Astro.site, Astro.url.pathname, mediaBase, siteSettings, {
  title: ov.title ?? '',
  description: ov.description,
  type: 'website',
  locale: 'en',
  imagePath: ov.image,
  noindex: ov.noindex,
  canonical: ov.canonical,
})
---

<PageLayout title={title} lang="en" themeOptions={themeOptions} siteSettings={siteSettings} feedLocales={localesForFeed} seo={seo}>
  {Content ? (
    <>
      <h1>{title}</h1>
      <Content />
    </>
  ) : (
    <p>No homepage is configured yet.</p>
  )}
</PageLayout>
