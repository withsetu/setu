---
// Dev-only in-editor preview: render the editor's current draft through the REAL theme +
// Markdoc component pipeline (same render path as the build → zero drift). Injected only in
// `astro dev` (see astro.config.mjs), so it never enters the static build.
export const prerender = false

import { parseMdoc } from '@setu/core'
import { Markdoc } from '@astrojs/markdoc/config'
import { Renderer } from '@astrojs/markdoc/components'
import { createContentComponent } from '@astrojs/markdoc/runtime'
import { assetsConfig } from '@astrojs/markdoc/runtime-assets-config'
import markdocConfig from '../../markdoc.config.mjs'
import PostLayout from '@theme/PostLayout.astro'
import PageLayout from '@theme/PageLayout.astro'
import CalloutWrapper from '../../../../blocks/callout/callout.astro'
import NoticeWrapper from '../../../../blocks/notice/notice.astro'
import ContactWrapper from '../../../../blocks/contact/contact.astro'
import QueryWrapper from '../../../../blocks/query/query.astro'
import RelatedWrapper from '../../../../blocks/related/related.astro'
import EmbedWrapper from '../../../../blocks/embed/embed.astro'
import HeroBlock from '@setu/blocks/hero.astro'
import ButtonBlock from '@setu/blocks/button.astro'
import ColumnsBlock from '@setu/blocks/columns.astro'
import ColumnBlock from '@setu/blocks/column.astro'
import ImageFigure from '@setu/image-astro/ImageFigure.astro'
import Image from '@setu/image-astro/Image.astro'
import Sub from '../components/Sub.astro'
import Sup from '../components/Sup.astro'
import Heading from '../components/Heading.astro'
import Paragraph from '../components/Paragraph.astro'
import Th from '../components/Th.astro'
import Td from '../components/Td.astro'
import { loadThemeOptions } from '../lib/site-config'

const apiUrl = import.meta.env.SETU_API_URL ?? 'http://localhost:4444'

let draft: { content: string; collection: string; locale: string; slug: string } | null = null
try {
  const res = await fetch(`${apiUrl}/preview`)
  if (res.ok) draft = await res.json()
} catch {
  // api unreachable → show the empty state below
}

// Build the Content component for the draft body, reusing the build's own markdoc runtime.
markdocConfig.nodes = { ...assetsConfig.nodes, ...markdocConfig.nodes }
// MUST list every tag AND node that markdoc.config.mjs renders via `component()` — the runtime
// only resolves the real component for entries present here; a MISSING one leaks the `component()`
// descriptor into the renderer and crashes with a cryptic "Cannot read properties of undefined
// (reading 'toString')" from @astrojs/react. Every standard/generated block belongs here.
// (Covered by the per-block render-smoke test: apps/site/test/preview-blocks.test.ts.)
const tagComponentMap = {
  callout: CalloutWrapper, notice: NoticeWrapper, contact: ContactWrapper,
  query: QueryWrapper, related: RelatedWrapper, embed: EmbedWrapper, hero: HeroBlock, button: ButtonBlock,
  columns: ColumnsBlock, column: ColumnBlock,
  image: ImageFigure, sub: Sub, sup: Sup,
}
const nodeComponentMap = { heading: Heading, paragraph: Paragraph, th: Th, td: Td, image: Image }

// Guard: if the draft uses a block tag with no registered renderer, fail LOUD and CLEAR
// (naming the tag) instead of leaking an undefined component into the React renderer.
const KNOWN_TAGS = new Set([...Object.keys(tagComponentMap), 'if', 'else', 'table', 'tbody', 'thead', 'tr'])
function assertTagsRegistered(node: { name?: string; tag?: string; children?: unknown[] } | null | undefined): void {
  if (!node || typeof node !== 'object') return
  const tag = (node as { tag?: string }).tag
  if (tag && !KNOWN_TAGS.has(tag)) {
    throw new Error(`preview: no renderer registered for block "{% ${tag} %}". Add it to tagComponentMap in apps/site/src/preview/preview.astro.`)
  }
  for (const child of (node as { children?: unknown[] }).children ?? []) {
    assertTagsRegistered(child as { name?: string; tag?: string; children?: unknown[] })
  }
}

let Content = null
let title = 'Preview'
let lang = 'en'
let isPost = true
if (draft) {
  const { frontmatter, body } = parseMdoc(draft.content)
  title = (frontmatter as { title?: string }).title ?? draft.slug
  lang = draft.locale
  isPost = draft.collection === 'post'
  const ast = Markdoc.parse(body)
  assertTagsRegistered(ast as { name?: string; tag?: string; children?: unknown[] })
  Content = createContentComponent(
    Renderer,
    JSON.stringify(ast),
    markdocConfig,
    {},
    tagComponentMap,
    nodeComponentMap,
  )
}

const themeOptions = loadThemeOptions()
const TemplateLayout = isPost ? PostLayout : PageLayout
---

{
  draft && Content ? (
    <TemplateLayout title={title} lang={lang} themeOptions={themeOptions}>
      <h1>{title}</h1>
      <Content />
    </TemplateLayout>
  ) : (
    <PageLayout title="Preview" lang="en" themeOptions={themeOptions}>
      <h1>Nothing to preview yet</h1>
      <p>Open an entry in the editor and hit Preview.</p>
    </PageLayout>
  )
}
