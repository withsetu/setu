---
import { getCollection } from 'astro:content'
import { selectPosts, entryUrlPath, excerpt, DEFAULT_LOCALE, type PostRow } from '@setu/core'
import { permalinkMap } from 'setu:permalinks'

const {
  collection = 'post',
  category,
  tag,
  locale,
  limit = 10,
  offset = 0,
  sort = 'newest',
  layout = 'grid',
  columns = 3,
  showImage = true,
} = Astro.props

// Grid honors an explicit column count (clamped 1–6); list is always single-column.
const cols = Math.min(6, Math.max(1, Number(columns) || 3))

const mediaBase = (import.meta.env.PUBLIC_SETU_MEDIA as string) ?? ''
const resolveImg = (s: string): string =>
  !s || /^https?:\/\//i.test(s) ? s : s.startsWith('/') ? `${mediaBase}${s}` : s

function toPostRow(entry: { id: string; data: Record<string, unknown>; body?: string }): PostRow {
  const [col = '', loc = '', ...rest] = entry.id.split('/')
  const d = entry.data
  const dateRaw = d['date'] ?? d['pubDate'] ?? d['updatedAt']
  // YAML parses an unquoted `date: 2026-06-20` into a Date; strings/numbers go through Date.parse.
  const parsed =
    dateRaw instanceof Date
      ? dateRaw.getTime()
      : typeof dateRaw === 'string' || typeof dateRaw === 'number'
        ? Date.parse(String(dateRaw))
        : NaN
  const strArr = (v: unknown): string[] =>
    Array.isArray(v) ? v.filter((x): x is string => typeof x === 'string') : []
  const str = (v: unknown): string => (typeof v === 'string' ? v : '')
  // Card excerpt: explicit frontmatter wins; else derive a plain-text snippet from the body.
  const cardExcerpt = str(d['description']) || str(d['summary']) || excerpt(entry.body ?? '', 160)
  return {
    id: entry.id,
    collection: col,
    locale: loc,
    slug: rest.join('/'),
    title: typeof d['title'] === 'string' ? (d['title'] as string) : entry.id,
    date: Number.isNaN(parsed) ? null : parsed,
    tags: strArr(d['tags']),
    categories: strArr(d['categories']),
    featuredImage: typeof d['featuredImage'] === 'string' ? (d['featuredImage'] as string) : undefined,
    excerpt: cardExcerpt || undefined,
    published: d['published'] === false ? false : undefined,
  }
}

const rows = (await getCollection('entries')).map((e) =>
  toPostRow({ id: e.id, data: e.data as Record<string, unknown>, body: (e as { body?: string }).body }),
)
const selected = selectPosts(rows, {
  collection,
  locale: locale ?? DEFAULT_LOCALE,
  category: category ?? undefined,
  tag: tag ?? undefined,
  sort,
  limit,
  offset,
})
const map = await permalinkMap()
const hrefOf = (p: PostRow) =>
  `/${map.get(p.id) ?? entryUrlPath({ collection: p.collection, locale: p.locale, slug: p.slug })}`

// Locale-aware short date ("Jun 30, 2026"). Full dateFormat/timezone setting wiring is #157;
// this honors the entry locale for month names and matches the stored default ('MMM D, YYYY').
// Rendered in UTC: a frontmatter date is a calendar date, not an instant, so it must not drift
// across the server/reader timezone (and it stays in step with the UTC `datetime` attribute).
const fmtDate = (ms: number, loc: string): string =>
  new Date(ms).toLocaleDateString(loc || DEFAULT_LOCALE, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  })
---

<ul class={`setu-posts setu-posts--${layout}${layout === 'grid' ? ` setu-posts--cols-${cols}` : ''}`}>
  {selected.map((p) => (
    <li class="setu-post-card">
      {showImage && p.featuredImage && (
        <a href={hrefOf(p)} class="setu-post-card__media">
          <img src={resolveImg(p.featuredImage)} alt={p.title} loading="lazy" />
        </a>
      )}
      <a href={hrefOf(p)} class="setu-post-card__title">{p.title}</a>
      {p.date !== null && (
        <time class="setu-post-card__date" datetime={new Date(p.date).toISOString().slice(0, 10)}>
          {fmtDate(p.date, p.locale)}
        </time>
      )}
      {p.excerpt && <p class="setu-post-card__excerpt">{p.excerpt}</p>}
    </li>
  ))}
</ul>

<style>
  .setu-posts { list-style: none; padding: 0; margin: 1.5rem 0; display: grid; gap: 1.25rem; }
  /* Grid uses the author's column count via LITERAL repeat() counts — not repeat(var(…)) or
     repeat(min(…)), which Safari/Firefox reject (the declaration is dropped and the grid
     collapses to one column). Then it steps down responsively: 2-up tablet, 1-up phone. */
  .setu-posts--cols-1 { grid-template-columns: 1fr; }
  .setu-posts--cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .setu-posts--cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .setu-posts--cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .setu-posts--cols-5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  .setu-posts--cols-6 { grid-template-columns: repeat(6, minmax(0, 1fr)); }
  @media (max-width: 900px) { .setu-posts--grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 560px) { .setu-posts--grid { grid-template-columns: 1fr; } }
  .setu-posts--list { grid-template-columns: 1fr; }
  .setu-post-card__media img {
    width: 100%; height: auto; aspect-ratio: 16 / 9; object-fit: cover;
    border-radius: var(--r-md, 8px); display: block;
  }
  .setu-post-card__title {
    display: inline-block; margin-top: 0.5rem;
    font-family: var(--font-heading, inherit); font-weight: 600;
    color: var(--text, inherit); text-decoration: none;
  }
  .setu-post-card__title:hover { color: var(--accent, #4f46e5); }
  .setu-post-card__date {
    display: block; margin-top: 0.25rem;
    font-size: 0.8125rem; color: var(--text-muted, #6b7280);
  }
  .setu-post-card__excerpt {
    margin: 0.4rem 0 0; font-size: 0.9375rem; line-height: 1.5;
    color: var(--text-muted, #4b5563);
    /* Clamp to 3 lines so uneven-length excerpts keep the grid tidy. */
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
