---
import type { GetStaticPaths, Page } from 'astro'
import PageLayout from '@theme/PageLayout.astro'
import ArchiveList from '@theme/ArchiveList.astro'
import { getCollection } from 'astro:content'
import { selectPosts, DEFAULT_LOCALE, type PostRow } from '@setu/core'
import { loadThemeOptions } from '../../lib/site-config'
import { loadSiteSettings } from '../../lib/site-settings'
import { toPostRow } from '../../lib/post-row'
import { pageSeo } from '../../lib/seo'
import { resolveMediaBase } from '@setu/image-astro'

export const getStaticPaths = (async ({ paginate }) => {
  // Posts per archive page comes from the Reading settings (Settings → Reading → Posts per page).
  // SETU_ARCHIVE_PER_PAGE overrides it for tests/demos without writing settings.json.
  const perPage = Number(process.env.SETU_ARCHIVE_PER_PAGE) || loadSiteSettings().reading.postsPerPage
  const rows = (await getCollection('entries')).map((e) =>
    toPostRow({ id: e.id, data: e.data as Record<string, unknown>, body: (e as { body?: string }).body }),
  )
  const posts = selectPosts(rows, {
    collection: 'post',
    locale: DEFAULT_LOCALE,
    sort: 'newest',
    limit: rows.length,
    offset: 0,
  })
  return paginate(posts, { pageSize: perPage })
}) satisfies GetStaticPaths

const { page } = Astro.props as { page: Page<PostRow> }

const themeOptions = loadThemeOptions()
const siteSettings = loadSiteSettings()
const mediaBase = resolveMediaBase(import.meta.env.PUBLIC_SETU_MEDIA, import.meta.env.DEV)
const seo = pageSeo(Astro.site, Astro.url.pathname, mediaBase, siteSettings, {
  title: 'Posts',
  type: 'website',
  locale: DEFAULT_LOCALE,
  prevPath: page.url.prev ?? undefined,
  nextPath: page.url.next ?? undefined,
})
---

<PageLayout title="Posts" lang="en" themeOptions={themeOptions} siteSettings={siteSettings} seo={seo}>
  <ArchiveList page={page} heading="Posts" basePath="/posts" mediaBase={mediaBase} />
</PageLayout>
