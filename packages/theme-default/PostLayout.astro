---
import Layout from './Layout.astro'
import RelatedReading from './RelatedReading.astro'
import type { SiteSettings } from '@setu/core'

interface RelatedItem {
  title: string
  href: string
}
interface Props {
  title: string
  lang?: string
  themeOptions?: Record<string, string>
  siteSettings?: SiteSettings
  related?: RelatedItem[]
}
const { title, lang = 'en', themeOptions = {}, siteSettings, related = [] } = Astro.props
---

<Layout title={title} lang={lang} themeOptions={themeOptions} siteSettings={siteSettings}>
  <article class="prose measure-post"><slot /></article>
  <div class="measure-post"><RelatedReading related={related} /></div>
</Layout>
