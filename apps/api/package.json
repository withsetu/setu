{
  "name": "@setu/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/app.ts",
  "types": "./src/app.ts",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
