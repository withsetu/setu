#!/bin/sh
# gitleaks pre-push hook (#325) — blocks secrets BEFORE they enter shared history.
# Local-first line of defence: it catches a secret while the commit can still be amended,
# which is cheaper than any server-side gate. CI's gitleaks job is the backstop (#218).
#
# Scans only the commit ranges being pushed. Scanner preference:
#   1. local `gitleaks` binary (fast)
#   2. the same digest-pinned Docker image CI uses — the reference is read from
#      .github/gitleaks/Dockerfile, the single source this hook and the workflow share
#      so the two can't drift apart on a bump (#817)
#   3. neither available -> WARN LOUDLY but allow the push (a hook that hard-fails on
#      missing tooling would block contributors who never installed anything; CI's
#      gitleaks job remains the backstop).
#
# Worktree note: pushes often happen from linked worktrees (.claude/worktrees/*) where
# $PWD/.git is a file. Objects and branch refs live in the MAIN checkout's .git, so the
# Docker fallback mounts the main repository root — SHA ranges resolve there regardless
# of which worktree initiated the push.
# Bypass (emergencies only): git push --no-verify

set -u

ZERO=0000000000000000000000000000000000000000

# Main repository root (parent of the common .git dir) — correct in worktrees too.
common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || exit 0
repo_root=$(dirname "$common_dir")

# Image reference, shared with .github/workflows/gitleaks.yml — see the header note.
# Deliberately NOT resolved from $repo_root: that is the MAIN checkout, and a push from a
# linked worktree must use the digest on the branch being pushed, not whatever the main
# checkout happens to have checked out (or, for a brand-new file, nothing at all). So try
# the hook's own directory and the current working tree first, and keep $repo_root only as
# a last resort. An empty result degrades to the "no scanner" branch below (loud warning,
# push allowed) rather than running `docker run ''`.
IMAGE=''
hook_dir=$(CDPATH='' cd -- "$(dirname -- "$0")" 2>/dev/null && pwd) || hook_dir=''
for candidate in \
  "${hook_dir:+$hook_dir/../.github/gitleaks/Dockerfile}" \
  ".github/gitleaks/Dockerfile" \
  "$repo_root/.github/gitleaks/Dockerfile"; do
  [ -n "$candidate" ] && [ -f "$candidate" ] || continue
  IMAGE=$(sed -n 's/^FROM  *//p' "$candidate" | head -n 1)
  [ -n "$IMAGE" ] && break
done

scan_range() {
  range="$1"
  if command -v gitleaks >/dev/null 2>&1; then
    gitleaks git --redact --exit-code 1 --log-opts "$range" "$repo_root"
  elif [ -n "$IMAGE" ] && command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    docker run --rm -v "$repo_root:/repo" "$IMAGE" git --redact --exit-code 1 --log-opts "$range" /repo
  else
    echo "" >&2
    echo "⚠️  gitleaks pre-push: NO scanner available (no gitleaks binary, and no Docker" >&2
    echo "⚠️  or no image reference in .github/gitleaks/Dockerfile)." >&2
    echo "⚠️  Push allowed UNSCANNED — CI's gitleaks job is the only secret gate now." >&2
    echo "⚠️  Fix: brew install gitleaks   (or start Docker)" >&2
    echo "" >&2
    return 0
  fi
}

status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue # branch deletion — nothing to scan
  if [ "$remote_sha" = "$ZERO" ]; then
    # New remote branch: scan commits not already on any remote-tracking ref.
    range="$local_sha --not --remotes"
  else
    range="$remote_sha..$local_sha"
  fi
  if ! scan_range "$range"; then
    status=1
  fi
done

if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "✗ push blocked: gitleaks found potential secret(s) in the outgoing commits." >&2
  echo "  Remove the secret AND rewrite the affected commits (amend/rebase) — simply" >&2
  echo "  deleting it in a new commit still leaks it in history. Then rotate the value." >&2
  echo "  (Emergency bypass: git push --no-verify — CI gitleaks will still catch it.)" >&2
fi
exit "$status"
