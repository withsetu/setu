---
import type { GetStaticPaths, Page } from 'astro'
import PageLayout from '@theme/PageLayout.astro'
import ArchiveList from '@theme/ArchiveList.astro'
import { getCollection } from 'astro:content'
import { selectPosts, DEFAULT_LOCALE, type PostRow } from '@setu/core'
import { loadThemeOptions } from '../../../lib/site-config'
import { loadSiteSettings } from '../../../lib/site-settings'
import { bucketPostsByTerm } from '../../../lib/build-cache'
import { toPostRow } from '../../../lib/post-row'
import { pageSeo } from '../../../lib/seo'
import { resolveMediaBase } from '@setu/image-astro'
import { permalinkMap } from 'setu:permalinks'

export const getStaticPaths = (async ({ paginate }) => {
  const perPage = Number(process.env.SETU_ARCHIVE_PER_PAGE) || loadSiteSettings().reading.postsPerPage
  const map = await permalinkMap()
  const rows = (await getCollection('entries')).map((e) =>
    toPostRow({ id: e.id, data: e.data as Record<string, unknown>, body: (e as { body?: string }).body }, map.get(e.id)),
  )
  // One filter+sort of the whole collection, then a single O(posts) bucketing pass by tag — instead
  // of a full filter+sort per distinct slug (#858). Iterating the newest-sorted `published`
  // preserves each bucket's order, and sorting the keys reproduces distinctTagSlugs' order, so the
  // emitted paths (and each page's posts) are byte-identical to the per-slug selectPosts.
  const published = selectPosts(rows, { collection: 'post', locale: DEFAULT_LOCALE, sort: 'newest', limit: rows.length, offset: 0 })
  const buckets = bucketPostsByTerm(published, (p) => p.tags)
  return [...buckets.keys()]
    .sort((a, b) => a.localeCompare(b))
    .flatMap((slug) => paginate(buckets.get(slug)!, { params: { slug }, pageSize: perPage }))
}) satisfies GetStaticPaths

const { page } = Astro.props as { page: Page<PostRow> }
const { slug } = Astro.params as { slug: string }
const themeOptions = loadThemeOptions()
const siteSettings = loadSiteSettings()
const mediaBase = resolveMediaBase(import.meta.env.PUBLIC_SETU_MEDIA, import.meta.env.DEV)
const heading = `Tag: ${slug}`
const basePath = `/tag/${slug}`
const seo = pageSeo(Astro.site, Astro.url.pathname, mediaBase, siteSettings, {
  title: heading,
  type: 'website',
  locale: DEFAULT_LOCALE,
  prevPath: page.url.prev ?? undefined,
  nextPath: page.url.next ?? undefined,
})
---

<PageLayout title={heading} lang="en" themeOptions={themeOptions} siteSettings={siteSettings} seo={seo}>
  <ArchiveList page={page} heading={heading} basePath={basePath} mediaBase={mediaBase} />
</PageLayout>
