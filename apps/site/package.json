  },
  "dependencies": {
    "@astrojs/markdoc": "2.0.3",
    "@astrojs/react": "6.0.1",
    "@astrojs/rss": "^4.0.18",
    "@setu/blocks": "workspace:*",
    "@setu/core": "workspace:*",
    "@setu/image-astro": "workspace:*",
    "@setu/theme-default": "workspace:*",
    "astro": "7.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "axe-core": "^4.12.1",
    "jsdom": "^25.0.1",
    "purgecss": "^8.0.0",
