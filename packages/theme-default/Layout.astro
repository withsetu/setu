---
import './theme.css'
import './site.css'

// Only the SELECTED `font` family (+ JetBrains mono) is bundled, not all 7 — the host build
// resolves the choice and serves this virtual module (see apps/site/astro.config.mjs +
// ./fonts.ts). A host that doesn't provide it gets an empty module (the theme degrades to
// system fonts), so the import is always safe.
import 'virtual:setu-fonts'

import { optionsToCss } from './options'
import type { SiteSettings, ResolvedSeo } from '@setu/core'

// Mirrors @setu/core's DEFAULT_LOCALE — inlined because theme-default has no runtime dep on
// @setu/core (only a type import). If the default locale ever becomes config-driven, update both.
const DEFAULT_LOCALE = 'en'

interface Props {
  title: string
  lang?: string
  themeOptions?: Record<string, string>
  siteSettings?: SiteSettings
  feedLocales?: string[]
  /** Resolved SEO head (title/canonical/og/twitter/…) computed by the app via @setu/core.
   *  When present it drives the head; absent → the legacy title/description/robots fallback. */
  seo?: ResolvedSeo
}
const { title, lang = 'en', themeOptions = {}, siteSettings, feedLocales = [], seo } = Astro.props
const overrideCss = optionsToCss(themeOptions)
const siteTitle = siteSettings?.general.title ?? 'Setu'
const tagline = siteSettings?.general.tagline ?? ''
const description = siteSettings?.general.description ?? ''
const docTitle = seo?.title ?? (title ? `${title} · ${siteTitle}` : siteTitle)
const feedLinks = siteSettings?.reading.feed.enabled
  ? (feedLocales.length ? feedLocales : [DEFAULT_LOCALE])
  : []
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{docTitle}</title>
    {seo ? (
      <>
        <link rel="canonical" href={seo.canonical} />
        {seo.meta.map((m) => (
          <meta name={m.name} property={m.property} content={m.content} />
        ))}
      </>
    ) : (
      <>
        {description && <meta name="description" content={description} />}
        {siteSettings?.reading.searchEngineVisible === false && (
          <meta name="robots" content="noindex, nofollow" />
        )}
      </>
    )}
    {feedLinks.map((loc) => (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={loc === DEFAULT_LOCALE ? siteTitle : `${siteTitle} (${loc.toUpperCase()})`}
        href={loc === DEFAULT_LOCALE ? '/rss.xml' : `/${loc}/rss.xml`}
        hreflang={loc}
      />
    ))}
    <style is:inline set:html={overrideCss}></style>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">{siteTitle}</a>
      {tagline && <span class="site-tagline">{tagline}</span>}
      <nav>
        <a href="/">Home</a>
        <a href="/page/about">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">Built with Setu</footer>
  </body>
</html>
