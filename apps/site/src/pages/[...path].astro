---
import PostLayout from '@theme/PostLayout.astro'
import PageLayout from '@theme/PageLayout.astro'
import { getCollection, render } from 'astro:content'
import { permalinkMap } from '../lib/permalinks'
import { loadThemeOptions } from '../lib/site-config'
import { loadSiteSettings } from '../lib/site-settings'
import { feedLocales } from '../lib/feed'
import { pageSeo } from '../lib/seo'
import { parsePageSeoOverride, localeAlternates } from '@setu/core'
import { resolvePostDate, parseDate } from '../lib/post-date'
import relations from '../../.setu/cache/relations.json'
import Image from '@setu/image-astro/Image.astro'
import { resolveMediaBase } from '@setu/image-astro'
import TaxonomyChips from '@theme/TaxonomyChips.astro'
import { categoryNameMap } from '@setu/core'
import { loadCategories } from '../lib/categories'
import { strArr } from '../lib/post-row'

export async function getStaticPaths() {
  const all = await getCollection('entries')
  const homepage = loadSiteSettings().reading.homepage
  const map = await permalinkMap()
  return all
    .filter((entry) => entry.id !== homepage && entry.id !== 'page/en/home')
    // #165: committed-but-unpublished entries get NO route at all. `published !== false`
    // is the only published-ness signal — same predicate as selectPosts/sitemap/feed.
    .filter(
      (entry) => (entry.data as { published?: unknown }).published !== false
    )
    .map((entry) => ({ params: { path: map.get(entry.id) }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const title = (entry.data as { title?: string }).title ?? entry.id
const [collection, locale = 'en'] = entry.id.split('/')
const TemplateLayout = collection === 'post' ? PostLayout : PageLayout
const themeOptions = loadThemeOptions()
const siteSettings = loadSiteSettings()
// Reuse the site's single source of truth for media resolution (same as Image.astro):
// dev → the local media API; prod-unset → relative; trailing slash trimmed.
const mediaBase = resolveMediaBase(import.meta.env.PUBLIC_SETU_MEDIA, import.meta.env.DEV)
const resolveImg = (s: string): string =>
  !s || /^https?:\/\//i.test(s) ? s : s.startsWith('/') ? `${mediaBase}${s}` : s
const rp = siteSettings.reading.relatedPosts
const relatedRaw = (relations as Record<string, { title: string; href: string; featuredImage?: string }[]>)[entry.id] ?? []
const related = rp.enabled
  ? relatedRaw.slice(0, rp.count).map((r) => ({
      title: r.title,
      href: r.href,
      ...(r.featuredImage ? { image: resolveImg(r.featuredImage) } : {}),
    }))
  : []
const featuredImage = typeof (entry.data as { featuredImage?: unknown }).featuredImage === 'string'
  ? (entry.data as { featuredImage: string }).featuredImage
  : undefined
const isPost = collection === 'post'
const catNames = isPost ? categoryNameMap(loadCategories()) : new Map<string, string>()
const postCategories = isPost
  ? strArr((entry.data as { categories?: unknown }).categories).map((slug) => ({ slug, name: catNames.get(slug) ?? slug }))
  : []
const postTags = isPost ? strArr((entry.data as { tags?: unknown }).tags) : []
const allEntries = await getCollection('entries')
const localesForFeed = feedLocales(
  allEntries.map((e) => ({ id: e.id, data: e.data as Record<string, unknown> })),
)
// hreflang alternates (#227): locale variants sharing this entry's collection+slug. Only
// published, routable variants are advertised; fewer than 2 → pageSeo emits no hreflang.
const permalinks = await permalinkMap()
const alternates = localeAlternates(entry.id, allEntries.map((e) => e.id))
  .filter((a) => {
    const e = allEntries.find((x) => x.id === a.id)
    return !!e && (e.data as { published?: unknown }).published !== false && permalinks.has(a.id)
  })
  .map((a) => ({ locale: a.locale, path: `/${permalinks.get(a.id)!}` }))
// Meta description from frontmatter; absent → the site description (resolveSeo fallback). A
// body-derived excerpt fallback can enrich this once @setu/core's `excerpt` lands on main (#174).
const d = entry.data as { description?: unknown; summary?: unknown }
const metaDescription =
  (typeof d.description === 'string' && d.description) ||
  (typeof d.summary === 'string' && d.summary) ||
  undefined
// Article dates (JSON-LD, posts only): published = frontmatter date → git → mtime; modified =
// frontmatter updatedAt/modified, else the publish date.
const entryFile = (entry as { filePath?: string }).filePath
const published = isPost ? resolvePostDate({ data: entry.data as Record<string, unknown>, filePath: entryFile }) : null
const modified = isPost
  ? (parseDate((entry.data as Record<string, unknown>).updatedAt) ??
     parseDate((entry.data as Record<string, unknown>).modified) ??
     published)
  : null
// Per-page SEO overrides (frontmatter `seo:`, authored in the editor) win over the derived defaults.
const ov = parsePageSeoOverride(entry.data)
const seo = pageSeo(Astro.site, Astro.url.pathname, mediaBase, siteSettings, {
  title: ov.title || title,
  description: ov.description || metaDescription || undefined,
  type: collection === 'post' ? 'article' : 'website',
  locale,
  imagePath: ov.image || featuredImage,
  noindex: ov.noindex,
  canonical: ov.canonical,
  datePublished: published?.toISOString(),
  dateModified: modified?.toISOString(),
  alternates,
})
---

<TemplateLayout title={title} lang={locale} themeOptions={themeOptions} siteSettings={siteSettings} related={related} feedLocales={localesForFeed} heading={rp.heading} showImage={rp.showImage} seo={seo}>
  {featuredImage && collection === 'post' && (
    <figure class="post-hero measure-post" slot="hero">
      <Image src={featuredImage} alt={title} sizes="(min-width: 40rem) 38rem, 100vw" />
    </figure>
  )}
  <h1>{title}</h1>
  <Content />
  {collection === 'post' && <TaxonomyChips categories={postCategories} tags={postTags} />}
</TemplateLayout>
