---
import PostLayout from '@theme/PostLayout.astro'
import PageLayout from '@theme/PageLayout.astro'
import { getCollection, render } from 'astro:content'
import { toUrlPath } from '../lib/url'
import { loadThemeOptions } from '../lib/site-config'
import { loadSiteSettings } from '../lib/site-settings'
import relations from '../../.setu/cache/relations.json'

export async function getStaticPaths() {
  const all = await getCollection('entries')
  return all
    .filter((entry) => entry.id !== 'page/en/home') // home renders at '/' via index.astro
    .map((entry) => ({ params: { path: toUrlPath(entry.id) }, props: { entry } }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const title = (entry.data as { title?: string }).title ?? entry.id
const [collection, locale = 'en'] = entry.id.split('/')
const TemplateLayout = collection === 'post' ? PostLayout : PageLayout
const themeOptions = loadThemeOptions()
const siteSettings = loadSiteSettings()
const related = (relations as Record<string, { title: string; href: string }[]>)[entry.id] ?? []
---

<TemplateLayout title={title} lang={locale} themeOptions={themeOptions} siteSettings={siteSettings} related={related}>
  <h1>{title}</h1>
  <Content />
</TemplateLayout>
