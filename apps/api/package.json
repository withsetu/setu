    "@setu/email-resend": "workspace:*",
    "@setu/email-templates": "workspace:*",
    "@setu/git-local": "workspace:*",
    "@setu/image-sharp": "workspace:*",
    "@setu/storage-local": "workspace:*",
    "hono": "4.12.26",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@setu/db-memory": "workspace:*",
    "@setu/git-http": "workspace:*",
    "@setu/git-memory": "workspace:*",
    "@setu/image-testing": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "better-sqlite3": "^12.10.1",
    "drizzle-orm": "^0.45.2",
    "isomorphic-git": "^1.38.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
