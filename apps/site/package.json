{
  "name": "@setu/site",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "predev": "node ../../scripts/gen-blocks.mjs && node ../../scripts/gen-relations.mjs",
    "dev": "astro dev",
    "prebuild": "node ../../scripts/gen-blocks.mjs && node ../../scripts/gen-relations.mjs",
    "build": "astro build",
    "genrelations": "node ../../scripts/gen-relations.mjs",
