node_modules/
dist/
.astro/
.DS_Store
*.log

# Turborepo local cache (task hashes + cached logs/outputs, per-package + root)
.turbo/

# Superpowers git worktrees (temporary, per-feature copies of the repo)
.superpowers/

# Claude Code local session/config state (never shared across machines) —
# except .claude/skills/, which is versioned team knowledge (see CLAUDE.md)
.claude/*
!.claude/skills/
!.claude/skills/**

# Design-skill session artifacts (local working files, regenerated per session)
.impeccable/
apps/*/DESIGN.md
apps/*/PRODUCT.md

# Dev/UAT content sandboxes (gitignored throwaway git repos seeded from content/)
.content-sandbox/

# Generated by scripts/gen-blocks.mjs (build-time, derived from blocks/)
apps/site/markdoc.blocks.generated.mjs

# Generated by scripts/gen-redirects.mjs (build-time, derived from redirects.json)
apps/site/public/_redirects

# Uploaded media (local dev storage)
.setu/

# Playwright E2E output (see e2e/)
e2e/test-results/
e2e/playwright-report/
e2e/.auth/

# vitest browser-mode failure screenshots (#293 — apps/admin/test-browser/**)
apps/admin/test-browser/__screenshots__/
