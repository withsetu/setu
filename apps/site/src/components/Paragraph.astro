---
// Node override so the editor's {% align %} annotation renders. #857: `align` is
// author-controlled and reaches an inline `text-align` sink, so it is clamped to an
// allowlist (an injection payload like `right;position:fixed` is dropped). Mirrors the
// `matches` constraint in markdoc.config.mjs; left/absent stays clean (no style).
const { align } = Astro.props
const alignOk = align === 'center' || align === 'right' || align === 'justify'
const style = alignOk ? `text-align:${align}` : undefined
---
<p style={style}><slot /></p>
