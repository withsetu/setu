---
// {% video %} (#178): self-hosted/uploaded video file as a plain HTML5 <video>.
// Pure static markup — edge-safe, zero server compute, no island. Provider embeds
// (YouTube/Vimeo) are the {% embed %} block, not this one. Root-relative /media/…
// srcs resolve against PUBLIC_SETU_MEDIA exactly like images (relative in a prod
// build when unset — never a baked-in localhost URL).
import './video.css'
import { resolveMediaBase } from '@setu/image-astro'
import { resolveMediaSrc } from '../safe-media-href'
import { videoPlaybackAttrs, videoClasses } from './video-attrs'

const { src = '', poster, caption, controls, autoplay, loop, muted, width } = Astro.props

const base = resolveMediaBase(import.meta.env.PUBLIC_SETU_MEDIA, import.meta.env.DEV)
// #857: route src/poster through the shared media resolver instead of a local copy that
// returned non-http/non-root strings unchanged — a protocol-relative `//host` (or its
// `/\host` twin) would otherwise load media from an attacker-chosen origin. http(s) and
// root-relative behavior is identical; anything else resolves to null (no element/attr).
// Tested in packages/blocks/test/safe-media-href.test.ts.
const resolvedSrc = resolveMediaSrc(src, base)
const resolvedPoster = poster ? resolveMediaSrc(poster, base) : null

const play = videoPlaybackAttrs({ controls, autoplay, loop, muted })
---
{resolvedSrc && (
  <figure class={videoClasses(width)}>
    <video
      class="blk-video-player"
      src={resolvedSrc}
      poster={resolvedPoster ?? undefined}
      controls={play.controls}
      autoplay={play.autoplay}
      loop={play.loop}
      muted={play.muted}
      playsinline={play.playsInline}
      preload="metadata"
    />
    {caption && <figcaption class="blk-video-caption">{caption}</figcaption>}
  </figure>
)}
