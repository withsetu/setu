{
  "name": "setu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Open-source, Git-backed, multi-topology CMS engine.",
  "license": "MIT",
  "scripts": {
    "content:seed": "node scripts/content-sandbox.mjs seed",
    "content:reset": "node scripts/content-sandbox.mjs reset",
    "auth:login-link": "node scripts/auth-login-link.mjs",
    "auth:reset-password": "pnpm --filter @setu/api run auth:reset-password",
    "dev": "node scripts/content-sandbox.mjs seed dev && concurrently -n api,admin,site -c blue,magenta,green \"SETU_API_PORT=4444 SETU_REPO_DIR=$PWD/.content-sandbox/dev SETU_MEDIA_DIR=$PWD/.setu/uploads pnpm --filter @setu/api dev\" \"VITE_SETU_API=http://localhost:4444 VITE_SETU_SITE=http://localhost:4321 pnpm --filter @setu/admin dev\" \"SETU_CONTENT_DIR=$PWD/.content-sandbox/dev/content SETU_API_URL=http://localhost:4444 PUBLIC_SETU_MEDIA=http://localhost:4444 SETU_MEDIA_DIR=$PWD/.setu/uploads pnpm --filter @setu/site dev\"",
    "dev:stop": "node scripts/free-ports.mjs 4321 4444 5173",
    "dev:fresh": "node scripts/free-ports.mjs 4321 4444 5173 && pnpm dev",
    "test": "pnpm -r test",
    "test:turbo": "turbo run test",
    "test:scripts": "node --test 'scripts/*.test.mjs'",
    "typecheck": "pnpm -r typecheck",
    "typecheck:turbo": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test -c e2e",
    "e2e:ui": "playwright test -c e2e --ui",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@setu/auth": "workspace:*",
    "@setu/db-sqlite": "workspace:*",
    "@types/node": "^22.19.21",
    "axe-core": "^4.12.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.65.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "sharp"
    ],
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-67mh-4wv8-2f99"
      ]
    },
    "overrides": {
      "brace-expansion@1": "1.1.16",
      "shell-quote": ">=1.9.0"
    }
  }
}
